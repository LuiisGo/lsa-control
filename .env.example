# ============================================================
# LSA Control — Variables de entorno
# ============================================================
# Copiar este archivo como `.env.local` (nunca commitear .env.local)
# En Netlify configurar todas estas variables en
# Site settings → Environment variables.

# ── API ─────────────────────────────────────────────────────
# URL del Google Apps Script Web App (reemplazar después del deploy)
# El proxy server-side de Next.js usa esta URL en /api/proxy.
NEXT_PUBLIC_API_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# ── Autenticación (next-auth) ───────────────────────────────
# OBLIGATORIO. Generar con: openssl rand -base64 32
# La aplicación falla con error explícito si NEXTAUTH_SECRET no está definido.
# Si el repo se hace público o se sospecha leak, ROTAR este valor.
NEXTAUTH_SECRET=replace-with-output-of-openssl-rand-base64-32

# URL pública del sitio. En desarrollo: http://localhost:3000
# En producción Netlify: https://controldiario-lsa.netlify.app
NEXTAUTH_URL=http://localhost:3000

# ============================================================
# Apps Script — Configurar en:
# Project Settings → Script Properties (no en este archivo)
# ============================================================
# SPREADSHEET_ID = ID del Google Sheet (default usa la hoja LSA Control)
# PASSWORD_SALT  = Salt aleatorio para hashear contraseñas (rotar invalidaria
#                  todas las contraseñas existentes — solo en setup inicial).
